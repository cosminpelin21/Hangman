<Window x:Class="Hangman.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Hangman Game" Height="600" Width="1000" 
        Background="#2D2D30" Foreground="White">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#252526"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#252526" Foreground="White" Padding="5">
            <MenuItem Header="_File">
                <MenuItem Header="_New Game" Command="{Binding NewGameCommand}" Foreground="Black"/>
                <MenuItem Header="_Open Game" Command="{Binding OpenGameCommand}" Foreground="Black"/>
                <MenuItem Header="_Save Game" Command="{Binding SaveGameCommand}" Foreground="Black"/>
                <MenuItem Header="_Statistics" Command="{Binding ShowStatsCommand}" Foreground="Black"/>
                <Separator/>
                <MenuItem Header="_Exit" Command="{Binding ExitCommand}" Foreground="Black"/>
            </MenuItem>
            <MenuItem Header="_Categories">
                <MenuItem Header="All categories" Command="{Binding ChangeCategoryCommand}" CommandParameter="All categories" Foreground="Black"/>
                <MenuItem Header="Cars" Command="{Binding ChangeCategoryCommand}" CommandParameter="Cars" Foreground="Black"/>
                <MenuItem Header="Countries" Command="{Binding ChangeCategoryCommand}" CommandParameter="Countries" Foreground="Black"/>
                <MenuItem Header="Rivers" Command="{Binding ChangeCategoryCommand}" CommandParameter="Rivers" Foreground="Black"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="#1E1E1E" Foreground="#CCCCCC" Padding="5">
            <StatusBarItem Content="{Binding CurrentLevel, StringFormat='Level: {0}'}" FontWeight="Bold"/>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Time left: "/>
                    <TextBlock Text="{Binding SecondsLeft}" Foreground="#FF4444" FontWeight="Bold"/>
                    <TextBlock Text="s"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Border DockPanel.Dock="Left" Width="300" BorderBrush="#3E3E42" BorderThickness="0,0,1,0" Margin="10">
            <StackPanel VerticalAlignment="Center">
                <Image Source="{Binding CurrentHangmanImage}" Stretch="Uniform" Height="250" Margin="0,0,0,20"/>

                <Ellipse Width="80" Height="80" Margin="0,10" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding UserLogo}" 
                                    Stretch="UniformToFill" 
                                    AlignmentX="Center" 
                                    AlignmentY="Center"/>
                    </Ellipse.Fill>
                </Ellipse>

                <TextBlock Text="{Binding UserName}" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="#007ACC" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Mistakes: " FontSize="16" VerticalAlignment="Center" Foreground="#AAAAAA"/>
                <ItemsControl ItemsSource="{Binding MistakesCollection}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="X" Foreground="#FF4444" FontSize="20" FontWeight="Bold" Margin="5,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Alphabet}" Margin="0,20" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Letter}" Width="45" Height="45" Margin="3"
                                Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding Letter}"
                                IsEnabled="{Binding IsActive}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                <TextBlock Text="{Binding CurrentCategory}" Foreground="#007ACC" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding HiddenWord}" FontSize="40" FontWeight="Bold" FontFamily="Consolas" Foreground="White"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>