<Window x:Class="Hangman.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hangman.Views"
        mc:Ignorable="d"
        Title="GameWindow" Height="600" Width="1000">
    <DockPanel>
        <Menu DockPanel.Dock="Top" FontSize="14" Padding="2">
            <MenuItem Header="_File">
                <MenuItem Header="_New Game" Command="{Binding NewGameCommand}"/>
                <MenuItem Header="_Open Game" Command="{Binding OpenGameCommand}"/>
                <MenuItem Header="_Save Game" Command="{Binding SaveGameCommand}"/>
                <MenuItem Header="_Statistics" Command="{Binding ShowStatsCommand}"/>
                <Separator/>
                <MenuItem Header="_Exit"  Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Categories">
                <MenuItem Header="All categories" 
              Command="{Binding ChangeCategoryCommand}" 
              CommandParameter="All categories"/>
                <MenuItem Header="Cars" 
              Command="{Binding ChangeCategoryCommand}" 
              CommandParameter="Cars"/>
                <MenuItem Header="Countries" 
              Command="{Binding ChangeCategoryCommand}" 
              CommandParameter="Countries"/>
                <MenuItem Header="Rivers" 
              Command="{Binding ChangeCategoryCommand}" 
              CommandParameter="Rivers"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="#f0f0f0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Level: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentLevel}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Time left: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding SecondsLeft}" Foreground="Red"/>
                    <TextBlock Text=" seconds"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Border DockPanel.Dock="Left" Width="350" BorderBrush="Gray" BorderThickness="0,0,1,0" Margin="10">
            <StackPanel VerticalAlignment="Center">
                <Image Source="{Binding CurrentHangmanImage}" Stretch="Uniform" Height="300"/>
                <TextBlock Text="{Binding UserName}" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Margin="0,10,0,0"/>
                <Image Source="{Binding UserLogo}" Width="60" Height="60"/>
            </StackPanel>
        </Border>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <TextBlock Text="Mistakes: " FontSize="16" VerticalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding MistakesCollection}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text=" X " Foreground="Red" FontSize="20" FontWeight="Bold" Margin="2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Alphabet}" Margin="0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Letter}" 
                                Width="40" Height="40" Margin="5"
                                Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding Letter}"
                                IsEnabled="{Binding IsActive}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <TextBlock Text="{Binding CurrentCategory}" 
               FontSize="24" 
               FontWeight="Bold" 
               Foreground="DarkBlue" 
               Margin="0,0,20,0"/>
                <TextBlock Text="{Binding HiddenWord}" 
           FontSize="32" 
           FontWeight="Bold" 
           FontFamily="Courier New"
           TextOptions.TextFormattingMode="Display"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
