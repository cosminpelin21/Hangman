<Window x:Class="Hangman.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Statistics" Height="450" Width="400" 
        WindowStartupLocation="CenterOwner" Background="#2D2D30">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding UserName, StringFormat='Stats for: {0}'}" 
                       FontSize="22" FontWeight="Bold" Foreground="#007ACC"/>
            <Separator Background="#3E3E42" Margin="0,10"/>

            <UniformGrid Columns="2" Margin="0,10">
                <TextBlock Text="Games played:" FontSize="14"/>
                <TextBlock Text="{Binding TotalGames}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                <TextBlock Text="Games won:" FontSize="14" Margin="0,5,0,0"/>
                <TextBlock Text="{Binding TotalWins}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#28A745" Margin="0,5,0,0"/>
            </UniformGrid>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Wins by category:" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="2" ItemsSource="{Binding CategoryWins}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  Background="#3E3E42" BorderThickness="0"
                  RowBackground="#2D2D30" AlternatingRowBackground="#353538"
                  Foreground="White" HeadersVisibility="Column">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#252526"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="Padding" Value="10,5"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" Binding="{Binding Key}" Width="*" />
                <DataGridTextColumn Header="Wins" Binding="{Binding Value}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>