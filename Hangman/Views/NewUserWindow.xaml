<Window x:Class="Hangman.Views.NewUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hangman.Views"
        mc:Ignorable="d"
        Title="NewUserWindow" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBlock Text="Nume utilizator:"/>
        <TextBox x:Name="UserNameTextBox" Margin="0,5,0,15"/>

        <TextBlock Text="Cale imagine:"/>
        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="ImagePathTextBox" Width="200" IsReadOnly="True"/>
            <Button Content="Alege..." Click="PickImage_Click" Margin="10,0,0,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Salvează" Click="Save_Click" Width="80" Margin="10,0"/>
            <Button Content="Anulează" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>
